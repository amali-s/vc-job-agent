# API key for job matching (Anthropic Claude)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Email delivery (use Gmail OR SendGrid)

# Option 1: Gmail (easiest)
GMAIL_USER=your.email@gmail.com
GMAIL_APP_PASSWORD=your_16_char_app_password
EMAIL_TO=your.email@gmail.com

# Option 2: SendGrid
# SENDGRID_API_KEY=your_sendgrid_api_key
# EMAIL_FROM=verified_sender@yourdomain.com
# EMAIL_TO=your.email@gmail.com

# Optional: Your portfolio URL to scrape for richer profile matching
PORTFOLIO_URL=https://your-portfolio.com/

# Optional: Comma-separated list of portfolio subpages to scrape (case studies, about, etc.)
# Example: PORTFOLIO_SUBPAGES=/about,/case-study-1,/case-study-2
PORTFOLIO_SUBPAGES=
